{
  "description": "Spike/mech-b — Stop hook only (isolated from full forgen stack).",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-guard.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
