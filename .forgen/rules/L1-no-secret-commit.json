{
  "rule_id": "L1-no-secret-commit",
  "category": "safety",
  "scope": "me",
  "trigger": "secret-leak",
  "policy": ".env / credentials.json / API key 를 커밋/푸시 금지. secret-filter hook 이 감지하면 즉시 중단.",
  "strength": "hard",
  "source": "explicit_correction",
  "status": "active",
  "evidence_refs": [],
  "render_key": "quality_safety.l1-no-secret-commit",
  "created_at": "2026-04-22T00:00:00.000Z",
  "updated_at": "2026-04-22T00:00:00.000Z",
  "enforce_via": [
    {
      "mech": "A",
      "hook": "PostToolUse",
      "verifier": {
        "kind": "pattern_match",
        "params": { "pattern": "AIza[0-9A-Za-z_-]{10,}|sk_(live|test)_[0-9A-Za-z]{24,}|AKIA[0-9A-Z]{16,}|ghp_[0-9A-Za-z]{30,}" }
      },
      "block_message": "L1-no-secret-commit: 커밋 대상에 API key 패턴 감지. 커밋 중단하고 .env 로 이동시켜라."
    }
  ]
}
